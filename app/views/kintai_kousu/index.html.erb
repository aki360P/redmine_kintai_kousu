<h2><%=l(:label_kintai_kousu)%> (<%= @year %>年<%= @month %>月 - <%= @user.name %>)</h2>

<div style="overflow-x: auto;">
  <%= render 'attendance_combined' %>
  <div class="contextual">
    <% prev_month = @month - 1
       prev_year = @year
       if prev_month < 1
         prev_month = 12
         prev_year -= 1
       end
       next_month = @month + 1
       next_year = @year
       if next_month > 12
         next_month = 1
         next_year += 1
       end
    %>
    <%= link_to "<<", "#{kintai_kousu_path}?year=#{prev_year}&month=#{prev_month}", class: 'icon icon-previous' %>
    <span style="margin: 0 10px;"><%= @year %>年 <%= @month %>月</span>
    <%= link_to ">>", "#{kintai_kousu_path}?year=#{next_year}&month=#{next_month}", class: 'icon icon-next' %>
  </div>

  <table class="list time-entries" style="width: 100%; table-layout: fixed;">
    <thead>
      <tr>
        <th style="text-align: left; width: 150px; padding: 4px 2px;">Work Time</th>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <th style="text-align: center; padding: 4px 1px;">
            <a href="#" class="kintai-open-attendance" data-day="<%= day %>" style="display:block;  color: #0056b3;">
              <%= day %><br>
              <span style="font-size: 0.8em; font-weight: normal; color: #0056b3;">
                <%= l(:day_names)[date.wday][0] %>
              </span>
            </a>
          </th>
        <% end %>
        <th style="text-align: center; width: 60px; background-color: #f0f0f0; font-weight: bold; padding: 4px 2px;">
          <%= l(:label_total) %>
        </th>
      </tr>
    </thead>
    <tbody>
      <tr style="background-color: #f7fbff;">
        <td style="text-align: left; padding: 4px 2px;">始業時刻</td>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <% record = @attendance_by_day[day] %>
          <% is_weekend = date.wday == 0 || date.wday == 6 %>
          <td
            class="kintai-attendance-cell kintai-attendance-source"
            data-day="<%= day %>"
            data-kind="start-time"
            data-start-time="<%= record&.start_time.to_s %>"
            data-end-time="<%= record&.end_time.to_s %>"
            data-attribute="<%= record&.work_attribute.to_s %>"
            style="text-align: center; padding: 4px 1px; <%= 'background-color: #eef5fb;' if is_weekend %>">
            <%= record&.start_time.present? ? record.start_time : '-' %>
          </td>
        <% end %>
        <td style="text-align: center; background-color: #f0f0f0; padding: 4px 2px;">-</td>
      </tr>
      <tr style="background-color: #f7fbff;">
        <td style="text-align: left; padding: 4px 2px;">終業時刻</td>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <% record = @attendance_by_day[day] %>
          <% is_weekend = date.wday == 0 || date.wday == 6 %>
          <td
            class="kintai-attendance-cell"
            data-day="<%= day %>"
            data-kind="end-time"
            style="text-align: center; padding: 4px 1px; <%= 'background-color: #eef5fb;' if is_weekend %>">
            <%= record&.end_time.present? ? record.end_time : '-' %>
          </td>
        <% end %>
        <td style="text-align: center; background-color: #f0f0f0; padding: 4px 2px;">-</td>
      </tr>
      <tr style="background-color: #f7fbff;">
        <td style="text-align: left; padding: 4px 2px;">属性</td>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <% record = @attendance_by_day[day] %>
          <% is_weekend = date.wday == 0 || date.wday == 6 %>
          <td
            class="kintai-attendance-cell"
            data-day="<%= day %>"
            data-kind="attribute"
            style="text-align: center; padding: 4px 1px; <%= 'background-color: #eef5fb;' if is_weekend %>">
            <%= record&.work_attribute.present? ? record.work_attribute : '-' %>
          </td>
        <% end %>
        <td style="text-align: center; background-color: #f0f0f0; padding: 4px 2px;">-</td>
      </tr>
      <tr style="background-color: #f7fbff;">
        <td style="text-align: left; padding: 4px 2px;">勤務時間</td>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <% is_weekend = date.wday == 0 || date.wday == 6 %>
          <td
            class="kintai-attendance-cell"
            data-day="<%= day %>"
            data-kind="work-hours"
            style="text-align: center; padding: 4px 1px; <%= 'background-color: #eef5fb;' if is_weekend %>">
            <span class="kintai-work-hours">-</span>
          </td>
        <% end %>
        <td style="text-align: center; background-color: #f0f0f0; padding: 4px 2px;">
          <span class="kintai-total-work-hours">-</span>
        </td>
      </tr>
      <tr style="background-color: #f7fbff;">
        <td style="text-align: left; padding: 4px 2px;">割増時間</td>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <% is_weekend = date.wday == 0 || date.wday == 6 %>
          <td
            class="kintai-attendance-cell"
            data-day="<%= day %>"
            data-kind="premium"
            style="text-align: center; padding: 4px 1px; <%= 'background-color: #eef5fb;' if is_weekend %>">
            <span class="kintai-premium">-</span>
          </td>
        <% end %>
        <td style="text-align: center; background-color: #f0f0f0; padding: 4px 2px;">
          <span class="kintai-total-premium">-</span>
        </td>
      </tr>
      <tr>
        <td style="text-align: left; width: 150px; padding: 4px 2px; font-weight: bold;">Project</td>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <td style="text-align: center; padding: 4px 1px; background-color: #f6f6f6; font-weight: bold;">
            <%= link_to "#{kintai_kousu_show_path}?year=#{@year}&month=#{@month}&day=#{day}", style: 'text-decoration: display: block; width: 100%; height: 100%;' do %>
              <%= day %><br>
              <span style="font-size: 0.8em; font-weight: normal;">
                <%= l(:day_names)[date.wday][0] %>
              </span>
            <% end %>
          </td>
        <% end %>
        <td style="text-align: center; background-color: #f0f0f0; padding: 4px 2px;">-</td>
      </tr>
      <% @project_daily_hours.sort_by { |project, _| project.name }.each do |project, daily_hours| %>
        <tr class="<%= cycle('odd', 'even') %>">
          <td style="text-align: left; font-weight: bold; padding: 4px 2px; word-wrap: break-word;">
            <%= link_to project.name, project_path(project) %>
          </td>
          <% (1..@last_day.day).each do |day| %>
            <% date = Date.new(@year, @month, day) %>
            <% hours = daily_hours[day] %>
            <% is_weekend = date.wday == 0 || date.wday == 6 %>
            <td style="text-align: center; padding: 4px 1px; <%= 'background-color: #fafafa;' if is_weekend %> <%= 'color: #999;' if hours == 0 %>">
              <%= hours > 0 ? ("%.2f" % hours) : '-' %>
            </td>
          <% end %>
          <td style="text-align: center; background-color: #f0f0f0; padding: 4px 2px;">
            <%= "%.2f" % @project_totals[project] %>
          </td>
        </tr>
      <% end %>
      
      <tr style="background-color: #e8f4f8; font-weight: bold;">
        <td style="text-align: left; padding: 4px 2px;">
          <%= l(:label_total) %>
        </td>
        <% (1..@last_day.day).each do |day| %>
          <% date = Date.new(@year, @month, day) %>
          <% hours = @daily_hours[day] %>
          <% is_weekend = date.wday == 0 || date.wday == 6 %>
          <td style="text-align: center; padding: 0; <%= 'background-color: #d8e8f0;' if is_weekend %>">
            <%= "%.2f" % hours %>
          </td>
        <% end %>
        <td style="text-align: center; background-color: #d0e0f0; font-weight: bold; padding: 4px 2px;">
          <%= "%.2f" % @total_hours %>
        </td>
      </tr>
    </tbody>
  </table>
</div>

<script>
  window.kintaiAttendanceData = <%= (@attendance_by_day || {}).transform_values { |record|
    {
      start_time: record&.start_time.to_s,
      end_time: record&.end_time.to_s,
      work_attribute: record&.work_attribute.to_s
    }
  }.to_json.html_safe %>;
</script>

<%= javascript_include_tag 'kintai_attendance_calc', plugin: 'redmine_kintai_kousu' %>

<script>
window.addEventListener('load', function() {
  const year = <%= @year %>;
  const month = <%= @month %>;
  function pad(n){ return n.toString().padStart(2, '0'); }

  // event delegation: handle clicks even if elements are added later
  document.addEventListener('click', function(e) {
    const el = e.target.closest('.kintai-open-attendance');
    if (!el) return;
    e.preventDefault();
    const day = el.dataset.day;
    if (!day) return;
    const dateStr = year + '-' + pad(month) + '-' + pad(day);

    const spentOn = document.getElementById('kintai_spent_on');
    if (spentOn) {
      spentOn.value = dateStr;
      spentOn.dispatchEvent(new Event('change', { bubbles: true }));
    }

    const attendanceDateInput = document.getElementById('kintai_attendance_date');
    if (attendanceDateInput) {
      attendanceDateInput.value = dateStr;
      attendanceDateInput.dispatchEvent(new Event('change', { bubbles: true }));
    }

    const attendanceModal = document.getElementById('kintai_attendance_modal');
    if (attendanceModal) {
      attendanceModal.classList.add('open');
      attendanceModal.setAttribute('aria-hidden', 'false');
    }
  });
});
</script>

<br>

<% if @time_entries.any? %>
  <h3><%= l(:label_details) %></h3>
  <div class="autoscroll">
    <table class="list time-entries">
      <thead>
        <tr>
          <th><%=l(:field_spent_on)%></th>
          <th><%=l(:label_project)%></th>
          <th><%=l(:field_issue)%></th>
          <th><%=l(:field_activity)%></th>
          <th><%=l(:field_hours)%></th>
          <th><%=l(:field_comments)%></th>
        </tr>
      </thead>
      <tbody>
        <% @time_entries.each do |entry| %>
          <tr class="<%= cycle('odd', 'even') %>">
            <td class="spent_on">
              <%= format_date(entry.spent_on) %>
            </td>
            <td class="project">
              <%= link_to_project(entry.project) %>
            </td>
            <td class="subject">
              <% if entry.issue %>
                <%= link_to_issue(entry.issue, :truncate => 50) %>
              <% else %>
                <em><%=l(:label_none)%></em>
              <% end %>
            </td>
            <td class="activity">
              <%= entry.activity.name %>
            </td>
            <td class="hours">
              <%= html_hours("%.2f" % entry.hours) %>
            </td>
            <td class="comments">
              <%= entry.comments %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="nodata">
    <%= l(:label_no_data) %>
  </p>
<% end %>
