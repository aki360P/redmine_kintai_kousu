<br>

<div id="kintai_gantt_sidebar" class="box">
  <h3><%= l(:label_kintai_kousu) %></h3>
  
  <div class="kintai-entry-form">
    <% if User.current.logged? %>
      <form id="kintai_gantt_entry_form" class="kintai-form">
        <div class="form-group">
          <label for="kintai_spent_on"><%= l(:field_spent_on) %></label>
          <input 
            type="date" 
            id="kintai_spent_on" 
            name="spent_on" 
            value="<%= Date.today.to_s %>"
            class="form-control"
            required>
        </div>

        <div class="form-group">
          <label for="kintai_issue_id">
            <%= l(:field_issue) %> <span class="required">*</span>
          </label>
          <input 
            type="text" 
            id="kintai_issue_id" 
            name="issue_id" 
            class="form-control"
            placeholder="チケットID (例: #123)"
            required>
        </div>

        <div class="form-group">
          <label for="kintai_hours"><%= l(:field_hours) %> <span class="required">*</span></label>
          <input 
            type="text" 
            id="kintai_hours" 
            name="hours" 
            class="form-control"
            required>
        </div>

        <div class="form-group">
          <label for="kintai_activity_id"><%= l(:field_activity) %> <span class="required">*</span></label>
          <select 
            id="kintai_activity_id" 
            name="activity_id" 
            class="form-control"
            required>
            <option value="">-- <%= l(:label_please_select) %> --</option>
            <% (@activities || TimeEntryActivity.active.order(:position)).each do |activity| %>
              <option value="<%= activity.id %>"><%= activity.name %></option>
            <% end %>
          </select>
        </div>

        <div class="form-group">
          <label for="kintai_comments"><%= l(:field_comments) %></label>
          <textarea 
            id="kintai_comments" 
            name="comments" 
            class="form-control" 
            rows="3"
            placeholder="<%= l(:label_optional) %>"></textarea>
        </div>

        <div class="button-group">
          <button type="submit" class="btn btn-secondary" id="kintai_submit_btn">
            <%= l(:button_create) %>
          </button>
          <div id="kintai_message" class="kintai-message" style="display: none; margin-top: 10px;"></div>
        </div>
      </form>

      <!-- 当日工数表示エリア -->
      <div id="kintai_daily_entries" class="kintai-daily-entries">
        <h4>当日工数 <span id="kintai_daily_total" class="kintai-total">0.0h</span></h4>
        <div id="kintai_entries_list" class="kintai-entries-list">
          <p class="loading-message">日付を選択してください</p>
        </div>
      </div>
    <% else %>
      <p><%= l(:notice_not_authorized) %></p>
    <% end %>
  </div>
</div>

<style>
.kintai-entry-form {
  padding: 10px;
}

.form-group {
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.form-group label {
  font-weight: bold;
  font-size: 0.9em;
  white-space: nowrap;
  min-width: 80px;
  margin: 0;
}

.form-control {
  flex: 1;
  padding: 4px 6px;
  border: 1px solid #ccc;
  border-radius: 3px;
  font-size: 0.9em;
  box-sizing: border-box;
}

.form-control:focus {
  outline: none;
  border-color: #4a90e2;
  box-shadow: 0 0 5px rgba(74, 144, 226, 0.5);
}

.required {
  color: #e67e22;
}

.optional {
  color: #95a5a6;
  font-weight: normal;
}

.help-text {
  color: #7f8c8d;
  margin: 5px 0 0 0;
}

.button-group {
  display: flex;
  gap: 8px;
  margin-top: 10px;
}

.btn {
  padding: 6px 12px;
  border: none;
  border-radius: 3px;
  cursor: pointer;
  font-size: 0.9em;
  font-weight: bold;
}

.btn-primary {
  background-color: #4a90e2;
  color: white;
}

.btn-primary:hover {
  background-color: #2e5c8a;
}

.btn-secondary {
  background-color: #6c757d !important;
  color: #fff !important;
  border: 1px solid #5a6268;
}

.btn-secondary:hover {
  background-color: #5a6268 !important;
}

.kintai-message {
  padding: 10px;
  border-radius: 3px;
  font-size: 0.9em;
}

.kintai-message.success {
  background-color: #d4edda;
  color: #155724;
  border: 1px solid #c3e6cb;
}

.kintai-message.error {
  background-color: #f8d7da;
  color: #721c24;
  border: 1px solid #f5c6cb;
}

#kintai_gantt_sidebar {
  margin-bottom: 20px;
  border: 1px solid #ddd;
  border-radius: 4px;
  background-color: #f9f9f9;
  position: relative;
}

#kintai_gantt_sidebar.kintai-sticky {
  position: fixed;
  top: 10px;
  z-index: 10;
}

.kintai-daily-entries {
  margin-top: 20px;
  padding: 10px;
  border-top: 1px solid #ddd;
}

.kintai-daily-entries h4 {
  font-size: 0.95rem;
  margin: 0 0 10px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.kintai-total {
  font-weight: bold;
  color: #4a90e2;
}

.kintai-entries-list {
  max-height: 300px;
  overflow-y: auto;
}

.kintai-entries-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.75rem;
  background-color: #fff;
}

.kintai-entries-table thead {
  background-color: #f0f0f0;
  position: sticky;
  top: 0;
}

.kintai-entries-table th {
  padding: 6px 4px;
  text-align: left;
  font-weight: bold;
  border-bottom: 2px solid #ddd;
  font-size: 0.7rem;
}

.kintai-entries-table td {
  padding: 6px 4px;
  border-bottom: 1px solid #e0e0e0;
}

.kintai-entries-table tbody tr:hover {
  background-color: #f5f5f5;
}

.entry-issue {
  font-weight: normal;
  color: #333;
}

.entry-activity {
  color: #666;
}

.entry-hours {
  font-weight: bold;
  color: #4a90e2;
  white-space: nowrap;
}

.entry-comments {
  color: #666;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading-message {
  text-align: center;
  color: #999;
  font-style: italic;
  padding: 20px;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('kintai_gantt_entry_form');
  const messageDiv = document.getElementById('kintai_message');
  const spentOnInput = document.getElementById('kintai_spent_on');
  const kintaiSidebar = document.getElementById('kintai_gantt_sidebar');
  const kintaiKousuCreateUrl = "<%= kintai_kousu_path %>";
  const kintaiKousuShowUrl = "<%= kintai_kousu_show_path %>";

  // 当日工数を読み込む関数
  function loadDailyEntries() {
    const spentOn = spentOnInput.value;
    if (!spentOn) {
      return;
    }

    const [year, month, day] = spentOn.split('-').map(Number);
    const entriesList = document.getElementById('kintai_entries_list');
    const totalSpan = document.getElementById('kintai_daily_total');

    entriesList.innerHTML = '<p class="loading-message">読み込み中...</p>';

    fetch(`${kintaiKousuShowUrl}?year=${year}&month=${month}&day=${day}`, {
      method: 'GET',
      headers: {
        'Accept': 'application/json'
      }
    })
    .then(response => {
      if (response.ok) {
        return response.json();
      } else {
        throw new Error('Failed to load entries');
      }
    })
    .then(data => {
      if (data.entries && data.entries.length > 0) {
        let total = 0;
        let html = `
          <table class="kintai-entries-table">
            <thead>
              <tr>
                <th>チケット</th>
                <th>作業分類</th>
                <th>時間</th>
                <th>コメント</th>
              </tr>
            </thead>
            <tbody>
        `;
        data.entries.forEach(entry => {
          total += parseFloat(entry.hours || 0);
          html += `
            <tr>
              <td class="entry-issue">
                ${entry.project ? '[' + entry.project.name + '] ' : ''}${entry.issue ? '#' + entry.issue.id + ' ' + entry.issue.subject : ''}
              </td>
              <td class="entry-activity">
                ${entry.activity ? entry.activity.name : ''}
              </td>
              <td class="entry-hours">${entry.hours}</td>
              <td class="entry-comments">${entry.comments || ''}</td>
            </tr>
          `;
        });
        html += `
            </tbody>
          </table>
        `;
        entriesList.innerHTML = html;
        totalSpan.textContent = total.toFixed(1) + 'h';
      } else {
        entriesList.innerHTML = '<p class="loading-message">工数がありません</p>';
        totalSpan.textContent = '0.0h';
      }
    })
    .catch(error => {
      console.error('Error loading entries:', error);
      entriesList.innerHTML = '<p class="loading-message">読み込みに失敗しました</p>';
      totalSpan.textContent = '0.0h';
    });
  }

  // 日付変更時に自動読み込み
  spentOnInput.addEventListener('change', loadDailyEntries);

  // 初期読み込み
  loadDailyEntries();

  // サイドバーをスクロールに追従
  if (kintaiSidebar) {
    let initialTop = kintaiSidebar.getBoundingClientRect().top + window.scrollY;
    let initialWidth = kintaiSidebar.offsetWidth;

    const updateSticky = () => {
      const shouldStick = window.scrollY > initialTop - 10;
      if (shouldStick) {
        kintaiSidebar.classList.add('kintai-sticky');
        kintaiSidebar.style.width = `${initialWidth}px`;
      } else {
        kintaiSidebar.classList.remove('kintai-sticky');
        kintaiSidebar.style.width = '';
      }
    };

    const recalc = () => {
      kintaiSidebar.classList.remove('kintai-sticky');
      kintaiSidebar.style.width = '';
      initialTop = kintaiSidebar.getBoundingClientRect().top + window.scrollY;
      initialWidth = kintaiSidebar.offsetWidth;
      updateSticky();
    };

    window.addEventListener('scroll', updateSticky, { passive: true });
    window.addEventListener('resize', recalc);
    updateSticky();
  }

  // ガントチャートのチケットsubjectクリックでチケットIDを入力
  const issueIdField = document.getElementById('kintai_issue_id');
  const ganttSubjects = document.querySelector('.gantt_subjects');
  if (issueIdField && ganttSubjects) {
    ganttSubjects.addEventListener('click', function(e) {
      const issueSubject = e.target.closest('.issue-subject');
      if (!issueSubject) {
        return;
      }

      const toggleInput = issueSubject.querySelector('input.toggle-selection');
      const inputValue = toggleInput ? toggleInput.value : '';
      const idMatch = issueSubject.id ? issueSubject.id.match(/issue-(\d+)/) : null;
      const issueId = inputValue || (idMatch ? idMatch[1] : '');

      if (!issueId) {
        return;
      }

      e.preventDefault();
      e.stopPropagation();

      issueIdField.value = issueId;
      issueIdField.focus();
      issueIdField.dispatchEvent(new Event('input', { bubbles: true }));
    });
  }

  // フォーム送信
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const spentOn = document.getElementById('kintai_spent_on').value;
    const [year, month, day] = spentOn.split('-').map(Number);

    const issueIdInput = document.getElementById('kintai_issue_id').value.trim();
    let issueId = '';
    
    // チケットIDから#を除去
    if (issueIdInput) {
      issueId = issueIdInput.replace(/^#/, '');
    }

    const formData = {
      time_entry: {
        issue_id: issueId,
        hours: document.getElementById('kintai_hours').value,
        activity_id: document.getElementById('kintai_activity_id').value,
        comments: document.getElementById('kintai_comments').value
      },
      year: year,
      month: month,
      day: day
    };

    console.log('Sending request to', kintaiKousuCreateUrl, formData);

    // time_entryを作成
    fetch(kintaiKousuCreateUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
      },
      body: JSON.stringify(formData)
    })
    .then(response => {
      console.log('Response status:', response.status);
      console.log('Response headers:', response.headers);
      
      // ステータスコードでチェック
      if (response.status === 201 || response.status === 200) {
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
          return response.json().then(data => {
            return { success: true, data: data };
          });
        } else {
          // JSON ではないが成功した場合（レコード作成成功）
          console.log('Success: Record created (non-JSON response)');
          return { success: true, data: { message: 'Record created successfully' } };
        }
      } else if (response.status === 422) {
        return response.json().then(data => {
          throw new Error(data.errors ? data.errors.join(', ') : 'バリデーションエラー');
        });
      } else {
        return response.text().then(text => {
          console.log('Error response body:', text);
          throw new Error('エラーが発生しました: ' + response.status);
        });
      }
    })
    .then(result => {
      if (result.success) {
        showMessage('<%= l(:notice_successful_create) %>', 'success');
        // 日付以外のフィールドをクリア（日付は保持）
        document.getElementById('kintai_issue_id').value = '';
        document.getElementById('kintai_hours').value = '';
        document.getElementById('kintai_activity_id').value = '';
        document.getElementById('kintai_comments').value = '';
        
        // 当日工数を再読み込み
        loadDailyEntries();
      }
    })
    .catch(error => {
      console.error('Error:', error);
      showMessage(error.message || '<%= l(:notice_failed_to_create_time_entry) %>', 'error');
    });
  });

  function showMessage(message, type) {
    messageDiv.textContent = message;
    messageDiv.className = `kintai-message ${type}`;
    messageDiv.style.display = 'block';
    
    if (type === 'success') {
      setTimeout(() => {
        messageDiv.style.display = 'none';
      }, 5000);
    }
  }
});
</script>
