<!-- Combined attendance modal, styles and scripts (for identical behavior/appearance with original gantt_sidebar) -->
<!-- Modal markup -->
<div id="kintai_attendance_modal" class="kintai-modal" aria-hidden="true">
  <div class="kintai-modal-backdrop" id="kintai_attendance_backdrop"></div>
  <div class="kintai-modal-content" role="dialog" aria-modal="true" aria-labelledby="kintai_attendance_title">
    <div class="kintai-modal-header">
      <h4 id="kintai_attendance_title">勤怠入力</h4>
      <button type="button" class="kintai-modal-close" id="kintai_attendance_close" aria-label="閉じる">&times;</button>
    </div>
    <p class="help-text">日付は上の「日付」を使用します。</p>
    <form id="kintai_attendance_form" class="kintai-form">
      <div class="form-group">
        <label for="kintai_attendance_date"><%= l(:field_spent_on) %></label>
        <input
          type="date"
          id="kintai_attendance_date"
          name="work_date"
          class="form-control"
          required>
      </div>
      <div class="form-group">
        <label for="kintai_work_start">始業時刻 <span class="required">*</span></label>
        <input
          type="time"
          id="kintai_work_start"
          name="start_time"
          class="form-control"
          required>
      </div>

      <div class="form-group">
        <label for="kintai_work_end">就業時刻 <span class="required">*</span></label>
        <input
          type="time"
          id="kintai_work_end"
          name="end_time"
          class="form-control"
          required>
      </div>

      <div class="form-group">
        <label for="kintai_work_attribute">属性</label>
        <select
          id="kintai_work_attribute"
          name="work_attribute"
          class="form-control">
          <option value="">-- 入力なし --</option>
          <option value="休暇">休暇</option>
          <option value="AM休">AM休</option>
          <option value="PM休">PM休</option>
          <option value="不就業">不就業</option>
          <option value="忌引">忌引</option>
          <option value="傷病">傷病</option>
          <option value="休日出勤">休日出勤</option>
        </select>
      </div>

      <div class="button-group">
        <button type="submit" class="btn btn-secondary" id="kintai_attendance_submit_btn">
          保存
        </button>
        <button type="button" class="btn" id="kintai_attendance_cancel_btn">
          閉じる
        </button>
        <div id="kintai_attendance_message" class="kintai-message" style="display: none; margin-top: 10px;"></div>
      </div>
    </form>
  </div>
</div>

<!-- Styles (copied from original gantt sidebar appearance) -->
<style>
.kintai-entry-form { padding: 10px; }
.kintai-header { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.kintai-header h3 { margin: 0; }
.form-group { margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.form-group label { font-weight: bold; font-size: 0.9em; white-space: nowrap; min-width: 80px; margin: 0; }
.form-control { flex: 1; padding: 4px 6px; border: 1px solid #ccc; border-radius: 3px; font-size: 0.9em; box-sizing: border-box; }
.form-control:focus { outline: none; border-color: #4a90e2; box-shadow: 0 0 5px rgba(74, 144, 226, 0.5); }
.required { color: #e67e22; }
.optional { color: #95a5a6; font-weight: normal; }
.help-text { color: #7f8c8d; margin: 5px 0 0 0; }
.button-group { display: flex; gap: 8px; margin-top: 10px; }
.btn { padding: 6px 12px; border: none; border-radius: 3px; cursor: pointer; font-size: 0.9em; font-weight: bold; }
.btn-primary { background-color: #4a90e2; color: white; }
.btn-primary:hover { background-color: #2e5c8a; }
.btn-secondary { background-color: #6c757d !important; color: #fff !important; border: 1px solid #5a6268; }
.btn-secondary:hover { background-color: #5a6268 !important; }
.kintai-modal { display: none; position: fixed; inset: 0; z-index: 1000; }
.kintai-modal.open { display: block; }
.kintai-modal-backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.45); }
.kintai-modal-content { position: relative; max-width: 520px; margin: 8vh auto; background: #fff; border-radius: 6px; padding: 16px 18px 12px 18px; z-index: 1; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.2); }
.kintai-modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
.kintai-modal-header h4 { margin: 0; }
.kintai-modal-close { border: none; background: none; font-size: 22px; line-height: 1; cursor: pointer; color: #666; }
.kintai-message { padding: 10px; border-radius: 3px; font-size: 0.9em; }
.kintai-message.success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
.kintai-message.error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
#kintai_gantt_sidebar { margin-bottom: 20px; border: 1px solid #ddd; border-radius: 4px; background-color: #f9f9f9; position: relative; }
#kintai_gantt_sidebar.kintai-sticky { position: fixed; top: 10px; z-index: 10; }
.kintai-daily-entries { margin-top: 20px; padding: 10px; border-top: 1px solid #ddd; }
.kintai-daily-entries h4 { font-size: 0.95rem; margin: 0 0 10px 0; display: flex; justify-content: space-between; align-items: center; }
.kintai-total { font-weight: bold; color: #4a90e2; }
.kintai-entries-list { max-height: 300px; overflow-y: auto; }
.kintai-entries-table { width: 100%; border-collapse: collapse; font-size: 0.75rem; background-color: #fff; }
.kintai-entries-table thead { background-color: #f0f0f0; position: sticky; top: 0; }
.kintai-entries-table th { padding: 6px 4px; text-align: left; font-weight: bold; border-bottom: 2px solid #ddd; font-size: 0.7rem; }
.kintai-entries-table td { padding: 6px 4px; border-bottom: 1px solid #e0e0e0; }
.kintai-entries-table tbody tr:hover { background-color: #f5f5f5; }
.entry-issue { font-weight: normal; color: #333; }
.entry-activity { color: #666; }
.entry-hours { font-weight: bold; color: #4a90e2; white-space: nowrap; }
.entry-comments { color: #666; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.loading-message { text-align: center; color: #999; font-style: italic; padding: 20px; }
</style>

<!-- Scripts (combined) -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('kintai_gantt_entry_form');
  const messageDiv = document.getElementById('kintai_message');
  const spentOnInput = document.getElementById('kintai_spent_on');
  const kintaiSidebar = document.getElementById('kintai_gantt_sidebar');
  const kintaiKousuCreateUrl = "<%= kintai_kousu_path %>";
  const kintaiKousuShowUrl = "<%= kintai_kousu_show_path %>";
  const kintaiAttendanceUrl = "<%= kintai_kousu_attendance_path %>";
  const attendanceForm = document.getElementById('kintai_attendance_form');
  const attendanceMessageDiv = document.getElementById('kintai_attendance_message');
  const attendanceModal = document.getElementById('kintai_attendance_modal');
  const attendanceOpenBtn = document.getElementById('kintai_attendance_open');
  const attendanceCloseBtn = document.getElementById('kintai_attendance_close');
  const attendanceBackdrop = document.getElementById('kintai_attendance_backdrop');
  const attendanceCancelBtn = document.getElementById('kintai_attendance_cancel_btn');
  const attendanceDateInput = document.getElementById('kintai_attendance_date');

  function loadDailyEntries() {
    const spentOn = (spentOnInput && spentOnInput.value) ? spentOnInput.value : (attendanceDateInput && attendanceDateInput.value ? attendanceDateInput.value : null);
    if (!spentOn) return;
    const [year, month, day] = spentOn.split('-').map(Number);
    const entriesList = document.getElementById('kintai_entries_list');
    if (!entriesList) return;
    const totalSpan = document.getElementById('kintai_daily_total');
    entriesList.innerHTML = '<p class="loading-message">読み込み中...</p>';
    fetch(`${kintaiKousuShowUrl}?year=${year}&month=${month}&day=${day}`, { method: 'GET', headers: { 'Accept': 'application/json' } })
    .then(response => { if (response.ok) return response.json(); throw new Error('Failed to load entries'); })
    .then(data => {
      if (data.entries && data.entries.length > 0) {
        let total = 0; let html = `<table class="kintai-entries-table"><thead><tr><th>チケット</th><th>作業分類</th><th>時間</th><th>コメント</th></tr></thead><tbody>`;
        data.entries.forEach(entry => { total += parseFloat(entry.hours || 0); html += `<tr><td class="entry-issue">${entry.project ? '[' + entry.project.name + '] ' : ''}${entry.issue ? '#' + entry.issue.id + ' ' + entry.issue.subject : ''}</td><td class="entry-activity">${entry.activity ? entry.activity.name : ''}</td><td class="entry-hours">${entry.hours}</td><td class="entry-comments">${entry.comments || ''}</td></tr>`; });
        html += `</tbody></table>`; entriesList.innerHTML = html; totalSpan.textContent = total.toFixed(2) + 'h';
      } else { entriesList.innerHTML = '<p class="loading-message">工数がありません</p>'; totalSpan.textContent = '0.00h'; }
    })
    .catch(error => { console.error('Error loading entries:', error); entriesList.innerHTML = '<p class="loading-message">読み込みに失敗しました</p>'; totalSpan.textContent = '0.00h'; });
  }

  const attendanceStartInput = document.getElementById('kintai_work_start');
  const attendanceEndInput = document.getElementById('kintai_work_end');
  const attendanceAttributeSelect = document.getElementById('kintai_work_attribute');
  const attendanceDisableAttributes = ['休暇', '忌引', '不就業', '傷病'];
  const attendanceRequireAttributes = ['休日出勤', 'AM休', 'PM休'];
  function applyAttendanceRules(attributeValue) { const shouldDisable = attendanceDisableAttributes.includes(attributeValue); const shouldRequire = attendanceRequireAttributes.includes(attributeValue) || !shouldDisable; attendanceStartInput.disabled = shouldDisable; attendanceEndInput.disabled = shouldDisable; attendanceStartInput.required = shouldRequire && !shouldDisable; attendanceEndInput.required = shouldRequire && !shouldDisable; if (shouldDisable) { attendanceStartInput.value = ''; attendanceEndInput.value = ''; } }
  function validateAttendanceInputs() { if (attendanceStartInput.disabled || attendanceEndInput.disabled) return true; if (!attendanceStartInput.value || !attendanceEndInput.value) { showMessage('始業時刻と就業時刻を入力してください', 'error', attendanceMessageDiv); return false; } return true; }

  let isAttendanceDateSyncing = false;
  function syncAttendanceDateFromMain() { if (!attendanceDateInput || !spentOnInput) return; isAttendanceDateSyncing = true; attendanceDateInput.value = spentOnInput.value; isAttendanceDateSyncing = false; }
  function syncMainDateFromAttendance() { if (!attendanceDateInput || !spentOnInput || isAttendanceDateSyncing) return; spentOnInput.value = attendanceDateInput.value; spentOnInput.dispatchEvent(new Event('change', { bubbles: true })); }
  function resetAttendanceForm() { if (attendanceStartInput) attendanceStartInput.value = ''; if (attendanceEndInput) attendanceEndInput.value = ''; if (attendanceAttributeSelect) attendanceAttributeSelect.value = ''; applyAttendanceRules(''); }

  function loadAttendanceData() {
    const spentOn = (spentOnInput && spentOnInput.value) ? spentOnInput.value : (attendanceDateInput && attendanceDateInput.value ? attendanceDateInput.value : null);
    if (!spentOn) { resetAttendanceForm(); return; }
    const [year, month, day] = spentOn.split('-').map(Number);
    const attendanceShowUrl = "<%= kintai_kousu_attendance_show_path %>";
    fetch(`${attendanceShowUrl}?year=${year}&month=${month}&day=${day}`, { method: 'GET', headers: { 'Accept': 'application/json' } })
    .then(response => { if (response.ok) return response.json(); throw new Error('Failed to load attendance data'); })
    .then(data => { if (data.success && data.kintai) { if (attendanceStartInput) attendanceStartInput.value = data.kintai.start_time || ''; if (attendanceEndInput) attendanceEndInput.value = data.kintai.end_time || ''; if (attendanceAttributeSelect) attendanceAttributeSelect.value = data.kintai.work_attribute || ''; applyAttendanceRules(attendanceAttributeSelect.value); } else { resetAttendanceForm(); } })
    .catch(error => { console.error('Error loading attendance data:', error); resetAttendanceForm(); });
  }

  // テーブル上の勤怠表示を更新する
  function applyAttendanceToTable(kintai) {
    if (!kintai || !kintai.work_date) return;
    try {
      const d = new Date(kintai.work_date);
      const day = d.getDate();

      // update start-time cell
      const startCell = document.querySelector(`td.kintai-attendance-cell[data-day="${day}"][data-kind="start-time"]`);
      if (startCell) {
        startCell.dataset.startTime = kintai.start_time || '';
        startCell.dataset.endTime = kintai.end_time || '';
        startCell.dataset.attribute = kintai.work_attribute || '';
        startCell.textContent = kintai.start_time && kintai.start_time !== '' ? kintai.start_time : '-';
      }

      // update end-time cell
      const endCell = document.querySelector(`td.kintai-attendance-cell[data-day="${day}"][data-kind="end-time"]`);
      if (endCell) {
        endCell.textContent = kintai.end_time && kintai.end_time !== '' ? kintai.end_time : '-';
      }

      // update attribute cell
      const attrCell = document.querySelector(`td.kintai-attendance-cell[data-day="${day}"][data-kind="attribute"]`);
      if (attrCell) {
        attrCell.textContent = kintai.work_attribute && kintai.work_attribute !== '' ? kintai.work_attribute : '-';
      }

      // update in-memory map if exists
      if (window.kintaiAttendanceData) {
        window.kintaiAttendanceData[day] = {
          start_time: kintai.start_time || '',
          end_time: kintai.end_time || '',
          work_attribute: kintai.work_attribute || ''
        };
      }

      // reload daily entries/totals for that date if sidebar exists
      if (typeof loadDailyEntries === 'function') {
        // if spent_on input is set to this date, reload; otherwise set and reload briefly
        const spentOn = (spentOnInput && spentOnInput.value) ? spentOnInput.value : null;
        const targetDate = kintai.work_date;
        if (spentOn === targetDate) {
          loadDailyEntries();
        }
      }

      // trigger recalculation/rendering performed by kintai_attendance_calc.js
      try {
        document.dispatchEvent(new Event('turbolinks:load'));
        document.dispatchEvent(new Event('turbo:load'));
        window.dispatchEvent(new Event('load'));
      } catch (e) {
        // ignore if events cannot be dispatched
      }
    } catch (e) {
      console.error('applyAttendanceToTable error', e);
    }
  }

  function openAttendanceModal() { if (!attendanceModal) return; attendanceModal.classList.add('open'); attendanceModal.setAttribute('aria-hidden', 'false'); syncAttendanceDateFromMain(); loadAttendanceData(); }
  function closeAttendanceModal() { if (!attendanceModal) return; attendanceModal.classList.remove('open'); attendanceModal.setAttribute('aria-hidden', 'true'); }

  if (attendanceOpenBtn) attendanceOpenBtn.addEventListener('click', openAttendanceModal);
  if (attendanceCloseBtn) attendanceCloseBtn.addEventListener('click', closeAttendanceModal);
  if (attendanceCancelBtn) attendanceCancelBtn.addEventListener('click', closeAttendanceModal);
  if (attendanceBackdrop) attendanceBackdrop.addEventListener('click', closeAttendanceModal);
  if (attendanceDateInput) attendanceDateInput.addEventListener('change', function() { syncMainDateFromAttendance(); loadAttendanceData(); });
  document.addEventListener('keydown', function(event) { if (event.key === 'Escape') closeAttendanceModal(); });
  if (attendanceAttributeSelect) attendanceAttributeSelect.addEventListener('change', function() { applyAttendanceRules(attendanceAttributeSelect.value); });
  if (spentOnInput) { spentOnInput.addEventListener('change', function() { loadDailyEntries(); loadAttendanceData(); syncAttendanceDateFromMain(); }); }
  if (typeof loadDailyEntries === 'function') loadDailyEntries();
  loadAttendanceData();

  if (kintaiSidebar) {
    let initialTop = kintaiSidebar.getBoundingClientRect().top + window.scrollY;
    let initialWidth = kintaiSidebar.offsetWidth;
    const updateSticky = () => { const shouldStick = window.scrollY > initialTop - 10; if (shouldStick) { kintaiSidebar.classList.add('kintai-sticky'); kintaiSidebar.style.width = `${initialWidth}px`; } else { kintaiSidebar.classList.remove('kintai-sticky'); kintaiSidebar.style.width = ''; } };
    const recalc = () => { kintaiSidebar.classList.remove('kintai-sticky'); kintaiSidebar.style.width = ''; initialTop = kintaiSidebar.getBoundingClientRect().top + window.scrollY; initialWidth = kintaiSidebar.offsetWidth; updateSticky(); };
    window.addEventListener('scroll', updateSticky, { passive: true }); window.addEventListener('resize', recalc); updateSticky();
  }

  const issueIdField = document.getElementById('kintai_issue_id');
  const ganttSubjects = document.querySelector('.gantt_subjects');
  if (issueIdField && ganttSubjects) {
    ganttSubjects.addEventListener('click', function(e) {
      const issueSubject = e.target.closest('.issue-subject'); if (!issueSubject) return; const toggleInput = issueSubject.querySelector('input.toggle-selection'); const inputValue = toggleInput ? toggleInput.value : ''; const idMatch = issueSubject.id ? issueSubject.id.match(/issue-(\d+)/) : null; const issueId = inputValue || (idMatch ? idMatch[1] : ''); if (!issueId) return; e.preventDefault(); e.stopPropagation(); issueIdField.value = issueId; issueIdField.focus(); issueIdField.dispatchEvent(new Event('input', { bubbles: true }));
    });
  }

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const spentOn = document.getElementById('kintai_spent_on').value; const [year, month, day] = spentOn.split('-').map(Number);
      const issueIdInput = document.getElementById('kintai_issue_id').value.trim(); let issueId = ''; if (issueIdInput) issueId = issueIdInput.replace(/^#/, '');
      const formData = { time_entry: { issue_id: issueId, hours: document.getElementById('kintai_hours').value, activity_id: document.getElementById('kintai_activity_id').value, comments: document.getElementById('kintai_comments').value }, year: year, month: month, day: day };
      fetch(kintaiKousuCreateUrl, { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' }, body: JSON.stringify(formData) })
      .then(response => { if (response.status === 201 || response.status === 200) { const contentType = response.headers.get('content-type'); if (contentType && contentType.includes('application/json')) return response.json().then(data => ({ success: true, data: data })); else return { success: true, data: { message: 'Record created successfully' } }; } else if (response.status === 422) { return response.json().then(data => { throw new Error(data.errors ? data.errors.join(', ') : 'バリデーションエラー'); }); } else { return response.text().then(text => { throw new Error('エラーが発生しました: ' + response.status); }); } })
      .then(result => { if (result.success) { showMessage('<%= l(:notice_successful_create) %>', 'success'); document.getElementById('kintai_issue_id').value = ''; document.getElementById('kintai_hours').value = ''; document.getElementById('kintai_activity_id').value = ''; document.getElementById('kintai_comments').value = ''; loadDailyEntries(); } })
      .catch(error => { console.error('Error:', error); showMessage(error.message || '<%= l(:notice_failed_to_create_time_entry) %>', 'error'); });
    });
  }

  if (attendanceForm) {
    attendanceForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const workDate = attendanceDateInput ? attendanceDateInput.value : spentOnInput.value; const startTime = attendanceStartInput.value; const endTime = attendanceEndInput.value; const workAttribute = attendanceAttributeSelect.value;
      if (!validateAttendanceInputs()) return;
      const payload = { kintai: { work_date: workDate, start_time: startTime, end_time: endTime, work_attribute: workAttribute } };
      fetch(kintaiAttendanceUrl, { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' }, body: JSON.stringify(payload) })
      .then(response => { if (response.status === 200 || response.status === 201) return response.json().then(data => ({ success: true, data })); return response.json().then(data => { throw new Error(data.errors ? data.errors.join(', ') : '保存に失敗しました'); }); })
      .then(result => { if (result.success) { showMessage('勤怠を保存しました', 'success', attendanceMessageDiv);
          // 更新を即時反映
          const kintai = result.data && result.data.kintai ? result.data.kintai : result.kintai || null;
          applyAttendanceToTable(kintai);
          attendanceAttributeSelect.value = '';
          applyAttendanceRules('');
          setTimeout(() => { closeAttendanceModal(); }, 800);
        } })
      .catch(error => { console.error('Attendance save error:', error); showMessage(error.message || '保存に失敗しました', 'error', attendanceMessageDiv); });
    });
  }

  function showMessage(message, type, targetDiv = messageDiv) { if (!targetDiv) return; targetDiv.textContent = message; targetDiv.className = `kintai-message ${type}`; targetDiv.style.display = 'block'; if (type === 'success') { setTimeout(() => { targetDiv.style.display = 'none'; }, 5000); } }
});
</script>

<script>
// delegated click handler for header dates (uses sidebar open button when available)
window.addEventListener('load', function() {
  const year = <%= @year %>;
  const month = <%= @month %>;
  function pad(n){ return n.toString().padStart(2, '0'); }
  document.addEventListener('click', function(e) {
    const el = e.target.closest('.kintai-open-attendance');
    if (!el) return;
    e.preventDefault();
    const day = el.dataset.day;
    if (!day) return;
    const dateStr = year + '-' + pad(month) + '-' + pad(day);
    const spentOn = document.getElementById('kintai_spent_on'); if (spentOn) { spentOn.value = dateStr; spentOn.dispatchEvent(new Event('change', { bubbles: true })); }
    const attendanceDateInput = document.getElementById('kintai_attendance_date'); if (attendanceDateInput) { attendanceDateInput.value = dateStr; attendanceDateInput.dispatchEvent(new Event('change', { bubbles: true })); }
    const sidebarOpenBtn = document.getElementById('kintai_attendance_open');
    if (sidebarOpenBtn) { sidebarOpenBtn.click(); return; }
    const attendanceModal = document.getElementById('kintai_attendance_modal'); if (attendanceModal) { attendanceModal.classList.add('open'); attendanceModal.setAttribute('aria-hidden', 'false'); }
  });
});
</script>
